{
    "name": "componenta/policy",
    "description": "Policy contracts, attributes, and providers for Componenta authorization",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/config": "^1.0",
        "componenta/di": "^1.0",
        "componenta/identity": "^1.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Policy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Componenta\\Policy\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Policy\\ConfigProvider"
            ]
        }
    }
}
